{
  "name": "vscode-venom",
  "displayName": "Venom Test Runner",
  "description": "Venom integration with Visual Studio Code",
  "version": "0.0.1",
  "publisher": "Thiht",
  "private": true,
  "license": "MIT",
  "repository": "https://github.com/Thiht/vscode-venom",
  "enabledApiProposals": [],
  "engines": {
    "vscode": "^1.51.0"
  },
  "categories": [
    "Testing"
  ],
  "activationEvents": [
    "workspaceContains:*.venom.yml"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "lint": "eslint . --ext .ts,.tsx",
    "watch": "tsc -watch -p ./",
    "download-api": "vscode-dts dev",
    "postdownload-api": "vscode-dts main",
    "postinstall": "npm run download-api"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^12.12.0",
    "@typescript-eslint/eslint-plugin": "^4.16.0",
    "@typescript-eslint/parser": "^4.16.0",
    "eslint": "^7.21.0",
    "typescript": "^4.5.5",
    "vscode-dts": "^0.3.3"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
